  "tokenColors": [
    {
      "name": "Keywords & Storage",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier",
        "variable.language.this",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#d87757"
      }
    },
    {
      "name": "Functions & Methods Call/Decl",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "meta.method-call entity.name.function",
        "meta.function-call entity.name.function",
        "entity.name.function.member"
      ],
      "settings": {
        "foreground": "#b39cf5"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#8fba6a"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#c3c1ba"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "variable.other.property",
        "meta.object-literal.key",
        "support.type.property-name",
        "variable.other.object.property"
      ],
      "settings": {
        "foreground": "#c4a66e"
      }
    },
    {
      "name": "Constants & Numbers",
      "scope": ["constant.numeric", "constant.language", "constant.other"],
      "settings": {
        "foreground": "#e89b76"
      }
    },
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6b6961",
        "fontStyle": "italic"
      }
    },
    {
      "name": "HTML/JSX Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag punctuation.definition.tag",
        "meta.tag.jsx",
        "support.class.component.jsx"
      ],
      "settings": {
        "foreground": "#5cacde"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "keyword": "#d87757",
    "storage": "#d87757",
    "function": "#b39cf5",
    "method": "#b39cf5",
    "variable": "#c3c1ba",
    "property": "#c4a66e",
    "string": "#8fba6a",
    "number": "#e89b76",
    "type": "#5cacde",
    "class": "#5cacde"
  }
}
